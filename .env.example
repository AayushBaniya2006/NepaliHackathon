OPENAI_API_KEY=sk-...

# --- ElevenLabs TTS (choose ONE path) ---
#
# A) Backend proxy (local: npm run dev:all) — key stays on the server
ELEVENLABS_API_KEY=xi-...
# ELEVENLABS_MODEL_ID=eleven_v3
#
# B) Frontend-only (e.g. Vercel static deploy, no Node API) — calls api.elevenlabs.io from the browser.
#    Set in Vercel Project → Environment Variables. The key is embedded in the JS bundle (treat as public).
# VITE_ELEVENLABS_API_KEY=xi-...
# Optional client defaults (match server / SessionResults):
# VITE_ELEVENLABS_MODEL_ID=eleven_v3
# VITE_TTS_PATIENT_MODEL_ID=eleven_v3
#
# If VITE_ELEVENLABS_API_KEY is set, the app uses direct ElevenLabs and ignores /api/voice/speak for TTS.

# Patient / Nepali in app — match server: eleven_v3 (REST uses language_code ne, not nep)
# Force Nepali for LLM + TTS when UI is English (hackathon demo): set to ne
# VITE_DEFAULT_PATIENT_LANGUAGE=ne
# ELEVEN_LABS_API_KEY=
# VITE_ELEVEN_LABS_API_KEY=
# Optional in local dev (server uses a fixed dev default). Required when NODE_ENV=production.
JWT_SECRET=
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173
